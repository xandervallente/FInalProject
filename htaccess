RewriteEngine On

# Redirect to HTTPS (optional, comment out if not needed)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Allow direct access to existing files and folders
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Route /views/pagename to /views/pagename.php
RewriteRule ^views/([a-zA-Z0-9_-]+)$ views/$1.php [L]

# Route /logout to /logout.php
RewriteRule ^logout$ logout.php [L]
